[Unit]
Description=CCS Coordinator API
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/cc-account-switcher
Environment=CCS_COORD_HOST=0.0.0.0
Environment=CCS_COORD_PORT=19090
Environment=CCS_COORD_STATE_FILE=/var/lib/ccs-coordinator/state.json
Environment=CCS_COORD_LEASE_TTL=180
EnvironmentFile=-/etc/default/ccs-coordinator
ExecStart=/usr/bin/node /root/cc-account-switcher/coordinator/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
